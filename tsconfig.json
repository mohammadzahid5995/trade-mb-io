{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": [
            "ES2020",
            "DOM"
        ],
        "strict": true,
        "moduleResolution": "node",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "types": [
            "node",
            "playwright/test"
        ]
    },
    "include": [
        "tests/**/*.ts",
        "pages/**/*.ts",
        "utils/**/*.ts",
        "playwright.config.ts"
    ]
}